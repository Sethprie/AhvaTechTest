@model AhvaTechTest.Models.ViewModels.ProfileViewModel

<div class="card p-4 mx-auto" style="max-width: 500px;">
    <h4>@Model.FullName</h4>
    <p><strong>Cargo:</strong> @Model.Position</p>
    <p><strong>Entidad:</strong> @Model.Entity</p>
    <p><strong>Estado:</strong> @Model.Status</p>

    <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-secondary mt-3">Cerrar sesión</a>
</div>