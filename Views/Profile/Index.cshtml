@model AhvaTechTest.Models.ViewModels.ProfileViewModel

<div class="d-flex">
    <!-- Menú lateral mock -->
    <div class="d-flex flex-column align-items-center bg-light border-end p-2" style="width: 60px; min-height: 80vh;">
        <button class="btn btn-sm mb-3" title="Expandir">☰</button>
        <button class="btn btn-sm mb-3" title="Home">🏠</button>
        <button class="btn btn-sm mb-3" title="Entidades">🏢</button>
        <button class="btn btn-sm mb-3" title="Documentos">📄</button>
        <button class="btn btn-sm mb-3" title="Buscar">🔍</button>
    </div>

    <div class="flex-grow-1 p-3">
        <!-- Card superior -->
        <div class="card p-3 mb-3">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-secondary rounded-circle" style="width: 70px; height: 70px;"></div>
                <div>
                    <h5 class="mb-0">@Model.FullName</h5>
                    <p class="mb-0">@Model.Position</p>
                    <p class="mb-0">@Model.Entity</p>
                    <span class="badge bg-success">@Model.Status</span>
                </div>
            </div>
        </div>

        <!-- 3 columnas -->
        <div class="row">
            <div class="col-md-4">
                <p><strong>Nombres:</strong><br />@Model.FirstNames</p>
                <p><strong>Tipo de Documento de Identidad:</strong><br />@Model.DocumentType</p>
                <p><strong>Nacionalidad:</strong><br />@Model.Nationality</p>
                <p><strong>Correo electrónico secundario (Opcional):</strong><br />@(Model.SecondaryEmail ?? "-")</p>
                <p><strong>Tipo de Contratación:</strong><br />@Model.ContractType</p>
            </div>
            <div class="col-md-4">
                <p><strong>Primer Apellido:</strong><br />@Model.LastNameFirst</p>
                <p><strong>N° de Documento de Identidad:</strong><br />@Model.DocumentNumber</p>
                <p><strong>Sexo:</strong><br />@Model.Gender</p>
                <p><strong>Teléfono Móvil:</strong><br />@Model.MobilePhone <span title="Editar" style="cursor:pointer;">✏️</span></p>
                <p><strong>Fecha de contratación:</strong><br />@Model.HireDate.ToString("dd/MM/yyyy")</p>
            </div>
            <div class="col-md-4">
                <p><strong>Segundo Apellido:</strong><br />@Model.LastNameSecond</p>
                <p><strong>Fecha de nacimiento:</strong><br />@Model.BirthDate.ToString("dd/MM/yyyy")</p>
                <p><strong>Correo electrónico principal:</strong><br />@Model.PrimaryEmail <span title="Editar" style="cursor:pointer;">✏️</span></p>
                <p>
                    <strong>Teléfono secundario (Opcional):</strong><br />
                    @(Model.SecondaryPhone ?? "-")
                    <select class="form-select form-select-sm d-inline-block w-auto ms-2" disabled>
                        <option selected>@(Model.SecondaryPhoneType ?? "Tipo")</option>
                        <option>Fijo</option>
                        <option>Móvil</option>
                    </select>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Aquí sigue tu modal de sesión existente, no lo borres -->

@section Scripts {
<script>
    const INACTIVITY_LIMIT_MS = 20 * 60 * 1000; // 20 minutos
    const COUNTDOWN_SECONDS = 49;

    let inactivityTimer;
    let countdownInterval;
    let secondsLeft = COUNTDOWN_SECONDS;
    let sessionModal;

    document.addEventListener("DOMContentLoaded", function () {
        sessionModal = new bootstrap.Modal(document.getElementById('sessionModal'));
        resetInactivityTimer();
        ["mousemove", "keydown", "click", "scroll"].forEach(evt =>
            document.addEventListener(evt, resetInactivityTimer)
        );
    });

    function resetInactivityTimer() {
        clearTimeout(inactivityTimer);
        inactivityTimer = setTimeout(showSessionModal, INACTIVITY_LIMIT_MS);
    }

    function showSessionModal() {
        secondsLeft = COUNTDOWN_SECONDS;
        document.getElementById("countdown").textContent = secondsLeft;
        sessionModal.show();

        countdownInterval = setInterval(function () {
            secondsLeft--;
            document.getElementById("countdown").textContent = secondsLeft;

            if (secondsLeft <= 0) {
                clearInterval(countdownInterval);
                window.location.href = '@Url.Action("ExpireSession", "Auth")';
            }
        }, 1000);
    }

    function extenderSesion() {
        clearInterval(countdownInterval);
        sessionModal.hide();
        resetInactivityTimer();
        fetch('@Url.Action("Ping", "Auth")'); // opcional: mantiene viva la sesión de servidor
    }
</script>
}