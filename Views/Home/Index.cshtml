@{
    ViewData["Title"] = "Bienvenida";
}

<div class="card p-4 mx-auto text-center" style="max-width: 500px;">
    <img src="~/images/welcome.png" alt="Bienvenida" class="mx-auto mb-3" style="max-width: 200px;" />

    <h3>Bienvenido al Sistema de Gestión</h3>

    <p>
        Este sistema te permite consultar y gestionar la información
        de tu perfil de forma rápida y segura.
    </p>
    <p>
        Para continuar, inicia sesión con tu documento de identidad
        y contraseña asignados.
    </p>

    <a asp-controller="Auth" asp-action="Login" class="btn btn-primary mt-2">Iniciar sesión</a>
</div>