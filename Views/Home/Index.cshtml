@model AhvaTechTest.Models.ViewModels.WelcomeViewModel
@{
    ViewData["Title"] = "Bienvenida";
}

<div class="card border-0 shadow-sm p-4 mx-auto text-center welcome-card">
    <img src="~/images/ceplan-illustration-success.png" alt="Bienvenida" class="mx-auto mb-3 welcome-illustration" />

    <h3>¡Bienvenida, @Model.FirstName!</h3>

    <p>Su cuenta en el aplicativo X está activada.</p>
    <p>Ya puede iniciar sesión.</p>

    <a asp-controller="Auth" asp-action="Login" class="btn btn-primary mt-2">Iniciar sesión</a>
</div>