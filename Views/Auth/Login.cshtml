@model AhvaTechTest.Models.ViewModels.LoginViewModel

<div class="card p-4 mx-auto" style="max-width: 400px;">
    <form asp-action="Login" method="post">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <div class="btn-group mb-3 w-100" role="group">
            <input type="radio" class="btn-check" name="DocumentType" id="dni" value="DNI" checked>
            <label class="btn btn-outline-primary" for="dni">DNI</label>

            <input type="radio" class="btn-check" name="DocumentType" id="ce" value="CE">
            <label class="btn btn-outline-primary" for="ce">CE</label>
        </div>

        <div class="mb-3">
            <label asp-for="DocumentNumber" class="form-label"></label>
            <input asp-for="DocumentNumber" class="form-control @(ViewData.ModelState["DocumentNumber"]?.Errors.Count > 0 ? "is-invalid" : "")" />
            <span asp-validation-for="DocumentNumber" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label">Contraseña</label>
            <input asp-for="Password" type="password" class="form-control @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <a asp-action="ForgotPassword">¿Olvidó su contraseña?</a>

        <button type="submit" class="btn btn-primary w-100 mt-3">Ingresar</button>
    </form>
</div>