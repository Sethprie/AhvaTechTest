@model AhvaTechTest.Models.ViewModels.LoginViewModel

<div class="card p-4 mx-auto mb-3" style="max-width: 400px;">
    <form asp-action="Login" method="post">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <div class="btn-group mb-3 w-100" role="group">
            <input type="radio" class="btn-check" name="DocumentType" id="dni" value="DNI" checked>
            <label class="btn btn-outline-primary" for="dni">DNI</label>

            <input type="radio" class="btn-check" name="DocumentType" id="ce" value="CE">
            <label class="btn btn-outline-primary" for="ce">CE</label>
        </div>

        <div class="mb-3">
            <label asp-for="DocumentNumber" class="form-label"></label>
            <input asp-for="DocumentNumber" id="documentNumber" class="form-control @(ViewData.ModelState["DocumentNumber"]?.Errors.Count > 0 ? "is-invalid" : "")" />
            <span asp-validation-for="DocumentNumber" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label">Contraseña</label>
            <div class="input-group">
                <input asp-for="Password" id="password" type="password" class="form-control @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                <button class="btn btn-outline-secondary" type="button" id="togglePassword">👁️</button>
            </div>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <a href="#" onclick="alert('Funcionalidad no contemplada en el alcance de esta prueba.'); return false;">¿Olvidó su contraseña?</a>

        <button type="submit" id="submitBtn" class="btn btn-primary w-100 mt-3" disabled>Ingresar</button>
    </form>
</div>

<div class="card p-3 mx-auto text-center" style="max-width: 400px;">
    <p class="mb-0">¿Necesita ayuda?, contacte con el área de soporte.</p>
</div>

@section Scripts {
<script>
    // Toggle mostrar/ocultar contraseña
    document.getElementById("togglePassword").addEventListener("click", function () {
        const pwd = document.getElementById("password");
        const isPassword = pwd.type === "password";
        pwd.type = isPassword ? "text" : "password";
        this.textContent = isPassword ? "🙈" : "👁️";
    });

    // Botón "Ingresar" deshabilitado hasta llenar ambos campos
    const docInput = document.getElementById("documentNumber");
    const pwdInput = document.getElementById("password");
    const submitBtn = document.getElementById("submitBtn");

    function checkFields() {
        submitBtn.disabled = !(docInput.value.trim() && pwdInput.value.trim());
    }

    docInput.addEventListener("input", checkFields);
    pwdInput.addEventListener("input", checkFields);
</script>
}